# Supabase (server-only). Get these from your Supabase project:
#   Project Settings → API → Project URL  and  service_role key
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret that unlocks "edit mode" in the browser.
# Pick anything; share it only with Krushi.
EDITOR_SECRET=

# Optional: also expose the secret to the client so the unlock prompt can be
# pre-filled on your own devices. Leave blank in production.
# (The real check is always server-side against EDITOR_SECRET.)
NEXT_PUBLIC_EDIT_ENABLED=1

# Per-page passwords for visitors who reach a page WITHOUT its NFC UID.
# JSON object: page id → password. Keys must match the page ids below:
#   navsari, landour, morse, random-day, calendar, miss-me, homesick,
#   truce, found-one, final-secret
# Example:
# PAGE_PASSWORDS={"navsari":"our first chai","morse":"dot dash","truce":"i am sorry"}
PAGE_PASSWORDS={}

# Optional: signing key for the unlock cookie (falls back to EDITOR_SECRET).
GATE_SECRET=
